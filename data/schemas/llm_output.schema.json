{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindpulse/schemas/llm_output.schema.json",
  "title": "MindPulse LLM Output",
  "description": "Fixed-schema JSON the LLM must produce. Validated by a deterministic safety validator before being shown to the user; invalid output triggers a template fallback.",
  "type": "object",
  "required": ["acknowledgement", "question", "action"],
  "additionalProperties": false,
  "properties": {
    "acknowledgement": {
      "type": "string",
      "maxLength": 200,
      "description": "Neutral, non-diagnostic explanation of the detected change."
    },
    "question": {
      "type": "string",
      "maxLength": 200,
      "description": "One reflective question."
    },
    "action": {
      "type": "object",
      "required": ["id", "title", "duration_minutes", "steps"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "one_minute_breathing", "two_minute_shutdown", "five_minute_walk",
            "one_task_planning", "phone_out_of_reach", "short_grounding",
            "prepare_sleep_environment", "drink_water_and_pause", "stretch_break",
            "message_someone_you_trust"
          ],
          "description": "Must be one of the approved action library IDs. The LLM may not invent an ID."
        },
        "title": { "type": "string", "maxLength": 60 },
        "duration_minutes": { "type": "integer", "enum": [1, 2, 5] },
        "steps": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": { "type": "string", "maxLength": 120 }
        }
      }
    }
  }
}
